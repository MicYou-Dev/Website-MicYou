---
interface Props {
	variant?: "filled" | "tonal" | "outlined" | "text";
	icon?: string;
	label?: string;
	href?: string;
}

const { variant = "filled", icon, label, href } = Astro.props;
---

{
	variant === "filled" && (
		<md-filled-button href={href} style="min-width: 140px">
			{icon && <md-icon slot="icon">{icon}</md-icon>}
			<slot>{label}</slot>
		</md-filled-button>
	)
}
{
	variant === "tonal" && (
		<md-filled-tonal-button href={href}>
			{icon && <md-icon slot="icon">{icon}</md-icon>}
			<slot>{label}</slot>
		</md-filled-tonal-button>
	)
}
{
	variant === "outlined" && (
		<md-outlined-button href={href} style="min-width: 140px">
			{icon && <md-icon slot="icon">{icon}</md-icon>}
			<slot>{label}</slot>
		</md-outlined-button>
	)
}
{
	variant === "text" && (
		<md-text-button href={href}>
			{icon && <md-icon slot="icon">{icon}</md-icon>}
			<slot>{label}</slot>
		</md-text-button>
	)
}

<script>
	import "@material/web/button/filled-button.js";
	import "@material/web/button/filled-tonal-button.js";
	import "@material/web/button/outlined-button.js";
	import "@material/web/button/text-button.js";
	import "@material/web/icon/icon.js";
</script>
